datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- USER & AUTHENTICATION ---

model User {
  id                       String    @id @default(uuid())
  email                    String    @unique
  password                 String
  name                     String?
  role                     Role      @default(CUSTOMER)
  isVerified               Boolean   @default(false)
  verificationToken        String?
  tokenExpires             DateTime?
  verificationEmailSentAt  DateTime?
  resetToken               String?
  resetTokenExpiry         DateTime?
  passwordResetEmailSentAt DateTime?
  status                   UserStatus @default(ACTIVE) 
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  // Relationships
  profile       UserProfile?
  orders        Order[]
  reviews       ProductReview[]
  cart          Cart?

  @@index([role])
}

model UserProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone      String?
  address    String?
  city       String?
  state      String?
  postalCode String?
  country    String   @default("Nepal")
  updatedAt  DateTime @updatedAt
}

// --- CATALOG (Products & Categories) ---

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique // For SEO: /category/fresh-vegetables
  image       String?
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  isActive    Boolean   @default(true)
  isFeatured  Boolean  @default(false)
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique // For SEO: /product/basmati-rice-5kg
  productCode String?  @unique // Barcode/UPC/EAN code
  description String?
  price       Decimal  @db.Decimal(10, 2) // This acts as the "Original Price"
  salePrice   Decimal? @db.Decimal(10, 2) // The "Discounted Price"
  discountType DiscountType? @default(NONE)
  stock       Int      @default(1)
  quantity    Int      @default(1)
  unit        String   @default("kg") // e.g., kg, gram, packet
  images      String[] // Array of image URLs
  isFeatured  Boolean  @default(false)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  status      ProductStatus @default(ACTIVE)
  reviews    ProductReview[]
  orderItems OrderItem[]
  cartItems  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([isFeatured])
}

// --- SHOPPING CART ---

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)

  @@unique([cartId, productId])
  @@index([productId])
}

// --- ORDERS ---

model Order {
  id          String      @id @default(uuid())
  orderNumber String      @unique // e.g., HS-1001
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  totalAmount Decimal     @db.Decimal(10, 2)
  status      OrderStatus @default(PENDING)
  orderType   OrderType   @default(DELIVERY)

  // Address Snapshot: Stores address at time of order in case user changes profile later
  shippingAddress String
  phone           String

  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal @db.Decimal(10, 2) // Price captured at time of purchase

  @@index([orderId])
  @@index([productId])
}

// --- SITE CONTENT & SETTINGS ---

model SiteSettings {
  id                      String  @id @default("singleton")
  storeName               String  @default("YUMA E-Commerce")
  contactEmail            String?
  contactPhone            String?
  deliveryFee             Decimal @default(0.00) @db.Decimal(10, 2)
  minOrderForFreeDelivery Decimal @default(50.00) @db.Decimal(10, 2)
  isStoreOpen             Boolean @default(true)
  maintenanceMode         Boolean @default(false)
  updatedAt               DateTime @updatedAt
}

model HeroSlider {
  id        String   @id @default(uuid())
  title     String?
  subtitle  String?
  image     String   // Background image URL
  link      String?  // Target URL when clicked
  isActive  Boolean  @default(true)
  priority  Int      @default(0) // Order of slides
  createdAt DateTime @default(now())
}

model ProductReview {
  id        String   @id @default(uuid())
  rating    Int      @default(5)
  comment   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  isActive  Boolean  @default(true)

  @@unique([userId, productId])
  @@index([productId, createdAt])
}

// --- ENUMS ---

enum Role {
  CUSTOMER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  DELETED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum DiscountType {
  NONE
  PERCENTAGE
  FLAT
}

enum OrderStatus {
  PENDING           // Order placed, payment not yet confirmed
  PROCESSING        // Kitchen/Warehouse is preparing the items
  READY_FOR_PICKUP  // Specific for local pickup orders
  SHIPPED           // Out for delivery (via courier)
  DELIVERED         // Received by customer
  COMPLETED         // Received by customer Pickup
  CANCELLED         // Order voided
  REFUNDED          // Payment returned
}

enum OrderType {
  DELIVERY
  PICKUP
}